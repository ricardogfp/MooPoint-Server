        "datasource": {
          "type": "influxdb",
          "uid": "afcuqgg3er2m8e"
        },
        "query": "from(bucket: \"${bucket}\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"position\")\n  |> filter(fn: (r) => r[\"node_id\"] =~ /${tracker:regex}/)\n  |> filter(fn: (r) => r[\"_field\"] == \"ext_tracker_rssi\")\n  |> aggregateWindow(every: 5m, fn: mean, createEmpty: false)",
        "refId": "A"
      }
    ],
    "title": "AI Range Analysis - RSSI Over Time",
    "type": "timeseries"
