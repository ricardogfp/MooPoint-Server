          "query": "import \"join\"\n\nrssi = from(bucket: \"loracow_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"position\")\n  |> filter(fn: (r) => r[\"_field\"] == \"rssi\")\n  |> filter(fn: (r) => r[\"device_id\"] =~ /${device_id}/)\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> rename(columns: {_value: \"RSSI\"})\n\nbatt = from(bucket: \"loracow_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"position\")\n  |> filter(fn: (r) => r[\"_field\"] == \"batt_percent\")\n  |> filter(fn: (r) => r[\"device_id\"] =~ /${device_id}/)\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> rename(columns: {_value: \"Battery %\"})\n\ngps_fix = from(bucket: \"loracow_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"position\")\n  |> filter(fn: (r) => r[\"_field\"] == \"ext_gps_fix_time\")\n  |> filter(fn: (r) => r[\"device_id\"] =~ /${device_id}/)\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> rename(columns: {_value: \"GPS Fix (s)\"})\n\njoin.time(left: rssi, right: batt, as: (l, r) => ({l with batt_percent: r[\"Battery %\"]}))\n  |> join.time(right: gps_fix, as: (l, r) => ({l with gps_fix_time: r[\"GPS Fix (s)\"]}))\n  |> yield(name: \"combined\")",
